<Window x:Class="BimStructure.Views.NewProjectView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Dự Án Mới" SizeToContent="Height"
        ResizeMode="NoResize" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- GROUP 1 -->
        <GroupBox Header="Thông tin dự án" Grid.Row="0" Margin="0 0 0 10">
            <StackPanel Margin="10">

                <StackPanel Orientation="Horizontal">
                    <TextBlock Width="120">Tên dự án</TextBlock>
                    <TextBox Width="250"
                             Text="{Binding Draft.ProjectName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0 5">
                    <TextBlock Width="120">Đường dẫn</TextBlock>
                    <TextBox Width="250" Text="{Binding Draft.FolderPath}" IsReadOnly="True"/>
                    <Button Content="..." Command="{Binding BrowseFolderCommand}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Width="120">ETABS DB</TextBlock>
                    <TextBox Width="250" Text="{Binding Draft.ImportFileName, Mode=OneWay}" IsReadOnly="True"/>
                    <Button Content="..." Command="{Binding BrowseFileCommand}"/>
                </StackPanel>

            </StackPanel>
        </GroupBox>
        
        <!-- GROUP 2 -->
        <GroupBox Header="Đơn vị" Grid.Row="1" Margin="0 0 0 10">
            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Width="120">Chiều dài</TextBlock>
                <TextBox Width="100" Text="{Binding Draft.LengthUnit}" IsReadOnly="True"/>

                <TextBlock Width="120" Margin="20 0 0 0">Lực</TextBlock>
                <TextBox Width="100" Text="{Binding Draft.ForceUnit}" IsReadOnly="True"/>
            </StackPanel>
        </GroupBox>
        <!-- GROUP 3 -->
        <GroupBox Header="Vật liệu" Grid.Row="2">
            <StackPanel Margin="10">

                <StackPanel Orientation="Horizontal">
                    <TextBlock Width="120">Bê tông</TextBlock>
                    <ComboBox Width="150"
                              ItemsSource="{Binding ConcreteMaterials}"
                              SelectedItem="{Binding Draft.SelectedConcreteMaterial}"
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0 5">
                    <TextBlock Width="120">Thép</TextBlock>
                    <ComboBox Width="150"
                              ItemsSource="{Binding SteelMaterials}"
                              SelectedItem="{Binding Draft.SelectedSteelMaterial}"
                              DisplayMemberPath="Name"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 10 0 0">

            <Button Content="Tạo mới"
                    Width="120"
                    Command="{Binding CreateProjectCommand}"/>

            <Button Content="Hủy"
                    Width="120"
                    Margin="10 0 0 0"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
